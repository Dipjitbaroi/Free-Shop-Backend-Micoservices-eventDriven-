generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DailySalesReport {
  id   String   @id @default(uuid())
  date DateTime @db.Date

  totalOrders       Int     @default(0)
  totalRevenue      Decimal @default(0) @db.Decimal(12, 2)
  totalItems        Int     @default(0)
  averageOrderValue Decimal @default(0) @db.Decimal(10, 2)

  completedOrders Int @default(0)
  cancelledOrders Int @default(0)
  pendingOrders   Int @default(0)

  newCustomers       Int @default(0)
  returningCustomers Int @default(0)

  codOrders     Int @default(0)
  bkashOrders   Int @default(0)
  otherPayments Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model VendorReport {
  id       String   @id @default(uuid())
  vendorId String
  date     DateTime @db.Date

  totalOrders  Int     @default(0)
  totalRevenue Decimal @default(0) @db.Decimal(12, 2)
  totalItems   Int     @default(0)
  commission   Decimal @default(0) @db.Decimal(10, 2)
  netRevenue   Decimal @default(0) @db.Decimal(10, 2)

  productViews     Int   @default(0)
  productClickRate Float @default(0)
  conversionRate   Float @default(0)

  averageRating Float @default(0)
  newReviews    Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, date])
  @@index([vendorId])
  @@index([date])
}

model ProductAnalytics {
  id        String   @id @default(uuid())
  productId String
  date      DateTime @db.Date

  views       Int     @default(0)
  uniqueViews Int     @default(0)
  addToCart   Int     @default(0)
  purchases   Int     @default(0)
  revenue     Decimal @default(0) @db.Decimal(10, 2)

  conversionRate Float @default(0)
  bounceRate     Float @default(0)

  searchImpressions Int @default(0)
  searchClicks      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
}

model CategoryAnalytics {
  id         String   @id @default(uuid())
  categoryId String
  date       DateTime @db.Date

  views        Int     @default(0)
  productViews Int     @default(0)
  purchases    Int     @default(0)
  revenue      Decimal @default(0) @db.Decimal(10, 2)

  topProductIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, date])
  @@index([categoryId])
  @@index([date])
}

model UserAnalytics {
  id   String   @id @default(uuid())
  date DateTime @db.Date

  newRegistrations Int @default(0)
  activeUsers      Int @default(0)
  totalSessions    Int @default(0)

  avgSessionDuration Int   @default(0)
  bounceRate         Float @default(0)

  mobileUsers  Int @default(0)
  desktopUsers Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model EventLog {
  id String @id @default(uuid())

  eventType String
  eventName String

  userId    String?
  sessionId String?

  entityType String?
  entityId   String?

  metadata Json?

  ipAddress String?
  userAgent String?
  referer   String?

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([eventName])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SearchAnalytics {
  id String @id @default(uuid())

  query            String
  resultsCount     Int     @default(0)
  clickedProductId String?

  userId    String?
  sessionId String?

  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}
