{
  "name": "@freeshop/product-service",
  "version": "1.0.0",
  "description": "Product catalog service for Free Shop",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": ["freeshop", "product", "catalog"],
  "license": "MIT",
  "dependencies": {
    "@freeshop/shared-types": "workspace:*",
    "@freeshop/shared-utils": "workspace:*",
    "@freeshop/shared-middleware": "workspace:*",
    "@freeshop/shared-events": "workspace:*",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "express": "^5.2.1",
    "prisma": "^7.6.0",
    "ioredis": "^5.9.3",
    "dotenv": "^16.6.1",
    "express-validator": "^7.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.2",
    "prisma": "^7.6.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
