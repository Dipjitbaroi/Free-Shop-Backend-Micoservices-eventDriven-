{
  "name": "@freeshop/auth-service",
  "version": "1.0.0",
  "description": "Authentication service for Free Shop",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "freeshop",
    "auth",
    "authentication"
  ],
  "license": "MIT",
  "dependencies": {
    "@freeshop/shared-events": "workspace:*",
    "@freeshop/shared-middleware": "workspace:*",
    "@freeshop/shared-types": "workspace:*",
    "@freeshop/shared-utils": "workspace:*",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "prisma": "^7.6.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
