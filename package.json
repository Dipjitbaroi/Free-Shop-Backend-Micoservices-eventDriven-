{
  "name": "free-shop-backend",
  "version": "1.0.0",
  "description": "Free Shop - Multi-vendor Organic Grocery eCommerce Platform (Microservices)",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "docker-compose -f docker-compose.dev.yml up --build",
    "start": "docker-compose up -d",
    "stop": "docker-compose down",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspaces --if-present",
    "db:seed": "npm run db:seed --workspaces --if-present"
  },
  "keywords": [
    "ecommerce",
    "microservices",
    "organic",
    "grocery",
    "multi-vendor"
  ],
  "author": "Free Shop Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
