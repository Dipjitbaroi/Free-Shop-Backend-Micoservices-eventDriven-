generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique // References auth service user
  email       String?
  firstName   String?
  lastName    String?
  phone       String?
  avatar      String?
  dateOfBirth DateTime?
  gender      Gender?
  
  addresses   Address[]
  wishlist    WishlistItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Address {
  id            String      @id @default(uuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  label         String?     // Home, Office, etc.
  fullName      String
  phone         String
  // Minimal Bangladesh address fields (following local e-commerce patterns)
  addressLine   String      // Detailed address: house/flat/road/block
  area          String?     // Specific area or neighborhood
  district      String      // District or City (required)
  upazila       String?     // Thana/Upazila
  postalCode    String?
  // Canonical delivery zone reference (used to look up delivery charges)
  zoneId        String      // required zone reference used for delivery charge lookup
  country       String      @default("Bangladesh")
  isDefault     Boolean     @default(false)
  type          AddressType @default(SHIPPING)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userProfileId])
  @@index([isDefault])
}

model WishlistItem {
  id            String      @id @default(uuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  productId     String
  addedAt       DateTime    @default(now())

  @@unique([userProfileId, productId])
  @@index([userProfileId])
  @@index([productId])
}

model RecentlyViewed {
  id        String   @id @default(uuid())
  userId    String
  productId String
  viewedAt  DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([viewedAt])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

enum SellerStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum SellerDepartment {
  ORDER_PROCESSING
  DELIVERY_ASSIGNMENT
  CUSTOMER_SUPPORT
  QUALITY_CONTROL
}

model SellerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique // References auth service user (with SELLER role)
  
  // Personal Info
  firstName     String
  lastName      String
  email         String   @unique
  phone         String
  avatar        String?
  
  // Employee Info
  employeeId    String   @unique // Unique staff number
  department    SellerDepartment
  assignedZone  String?  // Geographic zone or region for order/delivery assignment
  
  // Employment Status
  status        SellerStatus @default(ACTIVE)
  joinDate      DateTime @default(now())
  terminationDate DateTime?
  
  // Performance Metrics
  ordersProcessed Int      @default(0)
  assignedDeliveries Int   @default(0)
  successRate   Float?   @default(0) // %age of successful operations
  rating        Float?   @default(5)  // Customer rating/feedback
  
  // Commission & Payment
  commissionRate Decimal  @default(5) @db.Decimal(5, 2) // %age or flat rate
  bankDetails   Json?    // { accountNumber, accountHolderName, bankName, ifscCode }
  
  // Work Schedule & Contact
  workSchedule  Json?    // { monday: { start: "09:00", end: "18:00" }, ... }
  isAvailable   Boolean  @default(true)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([employeeId])
  @@index([department])
  @@index([assignedZone])
  @@index([status])
  @@index([isAvailable])
}
