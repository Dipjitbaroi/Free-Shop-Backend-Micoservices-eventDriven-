# NPM Configuration for VPS with slow/unstable networks
registry=https://registry.npmjs.org/

# Network timeout settings (1 hour + aggressive retries)
fetch-timeout=3600000
fetch-retries=20
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Connection optimization for Docker/VPS environments
maxsockets=10
max-old-space-size=4096

# Disable features that require network calls
legacy-peer-deps=true
audit=false
fund=false
progress=false

# Optional: Uncomment one of these lines for faster installs in specific regions:
# registry=https://registry.npmmirror.com/  # China mainland (Taobao mirror)
# registry=https://repo.npmmirror.com       # Alternative China mirror
# registry=https://registry.yarnpkg.com/    # Yarn mirror (good global coverage)
