generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  VENDOR
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum OAuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  APPLE
  PHONE
  EMAIL_LINK
  ANONYMOUS
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  phone             String?
  firstName         String
  lastName          String
  passwordHash      String?
  avatar            String?
  role              UserRole      @default(CUSTOMER)
  status            UserStatus    @default(PENDING_VERIFICATION)
  oauthProvider     OAuthProvider @default(LOCAL)
  oauthId           String?
  emailVerified     Boolean       @default(false)
  phoneVerified     Boolean       @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpires DateTime?
  lastLoginAt       DateTime?
  loginAttempts     Int           @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  refreshTokens     RefreshToken[]
  sessions          Session[]

  @@index([email])
  @@index([oauthProvider, oauthId])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  deviceId    String?
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  userAgent   String?
  ip          String?
  lastActive  DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("sessions")
}

model GuestToken {
  id          String   @id @default(uuid())
  guestId     String   @unique
  token       String   @unique
  cartId      String?
  email       String?
  phone       String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([guestId])
  @@index([token])
  @@map("guest_tokens")
}
