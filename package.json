{
  "name": "free-shop-backend",
  "version": "1.0.0",
  "description": "Free Shop - Multi-vendor Organic Grocery eCommerce Platform (Microservices)",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "pnpm --filter @freeshop/shared-types build && pnpm --filter @freeshop/shared-utils build && pnpm --filter @freeshop/shared-events build && pnpm --filter @freeshop/shared-middleware build && pnpm --filter ./services/* build",
    "dev": "docker-compose -f docker-compose.dev.yml up --build",
    "start": "docker-compose up -d",
    "stop": "docker-compose down",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspaces --if-present",
    "db:seed": "npm run db:seed --workspaces --if-present"
  },
  "keywords": [
    "ecommerce",
    "microservices",
    "organic",
    "grocery",
    "multi-vendor"
  ],
  "author": "Free Shop Team",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^4.18.0",
    "@types/hpp": "^0.2.7",
    "@types/node": "^25.5.2",
    "@types/on-finished": "^2.3.5",
    "typescript": "^6.0.2"
  }
}
