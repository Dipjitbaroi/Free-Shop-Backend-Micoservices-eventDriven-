# Application
NODE_ENV=development
LOG_LEVEL=debug

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
# Comma-separated allowed origins. Use * to allow all (development only).
CORS_ORIGIN=*

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
# Secret key required in the request body to create ADMIN / MANAGER accounts via POST /auth/admin/create
ADMIN_SECRET_KEY=change-this-to-a-strong-random-secret

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback

# User Service
USER_SERVICE_PORT=3002
USER_SERVICE_URL=http://user-service:3002

# Product Service
PRODUCT_SERVICE_PORT=3003
PRODUCT_SERVICE_URL=http://product-service:3003
PRODUCT_UPLOAD_MAX_IMAGES=5

# Order Service
ORDER_SERVICE_PORT=3004
ORDER_SERVICE_URL=http://order-service:3004

# Payment Service
PAYMENT_SERVICE_PORT=3005
PAYMENT_SERVICE_URL=http://payment-service:3005

# Inventory Service
INVENTORY_SERVICE_PORT=3006
INVENTORY_SERVICE_URL=http://inventory-service:3006

# Vendor Service
VENDOR_SERVICE_PORT=3007
VENDOR_SERVICE_URL=http://vendor-service:3007

# Notification Service
NOTIFICATION_SERVICE_PORT=3008
NOTIFICATION_SERVICE_URL=http://notification-service:3008

# Analytics Service
ANALYTICS_SERVICE_PORT=3009
ANALYTICS_SERVICE_URL=http://analytics-service:3009

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=freeshop_user
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=freeshop

# MongoDB (Analytics)
MONGODB_URI=mongodb://mongo:27017/freeshop_analytics
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_DATABASE=freeshop_analytics

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_strong_password

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=freeshop_mq
RABBITMQ_PASS=change_this_strong_password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://freeshop_mq:change_this_strong_password@rabbitmq:5672/

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=freeshop-assets

# Cloudinary (Alternative to S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# bKash Payment Gateway
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# EPS Payment Gateway
EPS_MERCHANT_ID=your-eps-merchant-id
EPS_API_KEY=your-eps-api-key
EPS_SECRET_KEY=your-eps-secret-key
EPS_BASE_URL=https://sandbox.eps-gateway.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Free Shop
SMTP_FROM_EMAIL=noreply@freeshop.com

# SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=FreeShop

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key!

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# Swagger public URL (used by Swagger UI Try-it-out)
PUBLIC_API_URL=http://localhost:3000/api/v1

SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@freeshop.com
