generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("ORDER_DATABASE_URL")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String?    // Can be null for guest carts
  guestId   String?    // For guest checkout
  items     CartItem[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime?  // For guest carts

  @@unique([userId])
  @@unique([guestId])
  @@index([userId])
  @@index([guestId])
  @@index([expiresAt])
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId String
  quantity  Int     @default(1)
  price     Float   // Price at time of adding (for reference)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  userId          String?       // Can be null for guest orders
  guestEmail      String?       // For guest checkout
  guestPhone      String?
  
  items           OrderItem[]
  
  // Shipping info (snapshot)
  shippingAddress Json
  // billingAddress  Json?  // disabled - not currently used
  
  // Order totals
  subtotal        Float
  shippingFee     Float         @default(0)
  discount        Float         @default(0)
  tax             Float         @default(0)
  total           Float
  
  // Coupon
  couponCode      String?
  couponDiscount  Float         @default(0)
  
  // Status tracking
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod
  
  // Timestamps
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  
  // Notes
  customerNote    String?
  adminNote       String?
  cancellationReason String?
  
  // Tracking
  trackingNumber  String?
  carrier         String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([orderNumber])
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  sellerId    String
  
  // Product snapshot
  productName String
  productSlug String
  productImage String?
  unit        String?
  
  quantity    Int
  price       Float     // Price at time of order
  discount    Float     @default(0)
  total       Float
  freeItemId  String?
  
  // Item status (for partial fulfillment)
  status      OrderItemStatus @default(PENDING)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
}

model Coupon {
  id              String      @id @default(uuid())
  code            String      @unique
  description     String?
  
  type            CouponType  @default(PERCENTAGE)
  value           Float       // Percentage or fixed amount
  
  minOrderAmount  Float?
  maxDiscount     Float?      // Cap for percentage discounts
  
  usageLimit      Int?        // Total usage limit
  usageCount      Int         @default(0)
  perUserLimit    Int         @default(1)
  
  // Restrictions
  applicableProducts Json?    // Product IDs (null = all products)
  applicableCategories Json?  // Category IDs
  applicableSellers Json?     // Seller IDs
  
  startDate       DateTime    @default(now())
  endDate         DateTime?
  
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startDate, endDate])
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String
  discount  Float
  usedAt    DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([couponId])
  @@index([userId])
}

// Platform-wide settings stored as key/value pairs. `value` is JSON to allow
// structured settings (e.g. deliveryCharges object).
model Setting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime?
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  COD
  BKASH
  NAGAD
  ROCKET
  EPS
  CARD
  BANK_TRANSFER
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}
